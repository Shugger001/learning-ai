# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (Whisper + content generation)
OPENAI_API_KEY=sk-your-openai-key

# Stripe (Pro subscription — required for paid upgrades)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Prefer STRIPE_PRO_PRICE_ID; STRIPE_CREDITS_PRICE_ID still accepted as fallback
STRIPE_PRO_PRICE_ID=price_your_pro_price
STRIPE_CREDITS_PRICE_ID=price_your_pro_price

# Optional: Uploadthing (if not using Supabase Storage exclusively)
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=
